{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-primary": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "chat",
      "api": "http://localhost:${WS_PORT_PRIMARY}/v1",
      "models": {
        "glm-4.7-flash": {
          "name": "GLM-4.7-Flash 64K",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "gpt-oss-120b": {
          "name": "GPT-OSS-120B 128K",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    },
    "llama-secondary": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "internal",
      "api": "http://localhost:${WS_PORT_SECONDARY}/v1",
      "models": {
        "qwen3-4b-instruct-2507": {
          "name": "Qwen3-4B (title agent -- do not select for chat)",
          "attachment": false,
          "reasoning": false,
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "llama-primary/glm-4.7-flash",
  "disabled_providers": ["opencode"],
  "agent": {
    "compaction": {
      "model": "llama-primary/gpt-oss-120b"
    },
    "title": {
      "model": "llama-secondary/qwen3-4b-instruct-2507"
    }
  },
  "mcp": {
    "library": {
      "type": "local",
      "command": [
        "${HOME}/.local/bin/uv",
        "run",
        "--project",
        "${WS_LIBRARY_ROOT}",
        "library"
      ],
      "enabled": true,
      "timeout": 180000
    }
  },
  "permission": {
    "edit": "ask",
    "webfetch": "allow",
    "skill": "ask",
    "bash": {
      "*": "ask",

      "ls *": "allow",
      "cat /etc/*": "allow",
      "cat /var/log/*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "systemctl status *": "allow",
      "systemctl list-units *": "allow",

      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct list*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct config *": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct status *": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pveversion*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pvesm status*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} ls *": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} cat /etc/*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo cat /etc/*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} cat /var/log/*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo cat /var/log/*": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} grep *": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} systemctl status *": "allow",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo systemctl status *": "allow",

      "rm *": "ask",
      "rm -rf *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct destroy*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct stop*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} sudo pct rm*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} pct destroy*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} pct stop*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} pct rm*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} rm *": "ask",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} rm -rf *": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} reboot*": "deny",
      "ssh ${WS_PROXMOX_USER}@${WS_PROXMOX_HOST} shutdown*": "deny"
    }
  },
  "plugin": []
}
