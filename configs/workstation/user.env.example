# Workstation per-user environment variables.
#
# Install location: ~/.config/workstation/user.env
# Owner: the user, mode 0644.
# Sourced by:
#   - the launcher and any per-user script that needs paths
#
# This file describes *paths the current user owns*. Two users on the
# same workstation each have their own user.env with their own values.
#
# To install: copy this file to ~/.config/workstation/user.env and edit
# values to match. The launcher will source it automatically.

# ── Repo checkouts ─────────────────────────────────────────────────────────

# Path to your clone of the workstation umbrella repo.
WS_USER_ROOT=$HOME/Documents/Repos/2gpu-local-ai-workstation

# Path to the Library MCP repo. Library is a submodule of the umbrella;
# this resolves inside your umbrella checkout. If you cloned the umbrella
# without --recurse-submodules, run `git submodule update --init` to
# populate this path.
WS_LIBRARY_ROOT=$WS_USER_ROOT/Library

# ── Editor profile paths ──────────────────────────────────────────────────

# Zed isolated profile for the second-opinion workflow. The launcher
# passes this to `zed --user-data-dir`. Keep stable; Zed re-initializes
# from scratch if the path changes.
WS_ZED_PROFILE_DIR=$HOME/.local/share/zed-second-opinion

# ── Personal model overrides ──────────────────────────────────────────────

# Optional. If you have your own GGUFs that you do not want to share
# with the system catalog, put them here and reference them from a
# unit override. Empty by default; nothing reads from this if unset.
WS_USER_MODELS_DIR=$HOME/models-experiments
