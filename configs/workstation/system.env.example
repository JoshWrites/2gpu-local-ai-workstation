# Workstation system-wide environment variables.
#
# Install location: /etc/workstation/system.env
# Owner: root, mode 0644 (world-readable; no secrets here).
# Sourced by:
#   - systemd unit files via `EnvironmentFile=/etc/workstation/system.env`
#   - launcher and management scripts via `source`
#
# This file describes the workstation's *hardware and service shape*. Values
# are decisions, not secrets. Things that change per-user belong in
# user.env. Things that should not be public belong in secrets.env.
#
# To install: copy this file to /etc/workstation/system.env, edit values
# to match your machine, then `sudo systemctl daemon-reload` to pick up
# new EnvironmentFile contents.

# ── Local users with passwordless llama-* control ─────────────────────────

# Space-separated list of local usernames who should be allowed to run
# `systemctl start/stop/restart` on the llama-* services without a sudo
# password. install-systemd-units.sh renders this into the polkit rule
# at /etc/polkit-1/rules.d/10-llama-services.rules. Names are validated
# (alphanumerics + underscore + hyphen) before substitution.
#
# Customize for your machine. Empty list means every llama-* start/stop
# will prompt for a password, which breaks the launcher's silent-start UX.

WS_LLAMA_USERS="your-username-here"

# ── Hardware identity ──────────────────────────────────────────────────────

# Human-readable card names; used in unit Descriptions and launcher text.
WS_GPU_PRIMARY_NAME="7900 XTX"
WS_GPU_PRIMARY_VRAM_GB=24
WS_GPU_SECONDARY_NAME="5700 XT"
WS_GPU_SECONDARY_VRAM_GB=8

# Vulkan device indices as llama.cpp enumerates them. These are *not* the
# same as rocm-smi's device indices; verify with `vulkaninfo --summary`
# or by trial. The launcher and unit files use these to pin services to
# the right card.
WS_GPU_PRIMARY_DEVICE=Vulkan0
WS_GPU_SECONDARY_DEVICE=Vulkan1

# ── Model catalog location ────────────────────────────────────────────────

# Canonical model catalog. System-shared, root-owned, world-readable so
# any local user can read GGUFs without permission gymnastics.
#
# The llama-server binary path is *not* in this file. systemd resolves
# the first ExecStart token before applying env-var substitution, so the
# binary path cannot be parameterized via EnvironmentFile. The primary
# router unit uses /usr/local/lib/llama.cpp-hip/llama-server (HIP build,
# gfx1100); the secondary/embed/coder units use the Vulkan build at
# /usr/local/lib/llama.cpp/llama-server (gfx1010, 5700 XT). Updating
# either binary means editing the relevant unit files by hand.
WS_MODELS_DIR=/var/lib/llama-models

# ── Port assignments ───────────────────────────────────────────────────────

# Stable across deploys. Cross-referenced in:
#   - the four llama-* systemd units
#   - the launcher's ENDPOINTS array
#   - llama-shutdown's PORTS map
#   - opencode.json provider URLs
#   - the regression script's assertions

WS_PORT_PRIMARY=11434
WS_PORT_SECONDARY=11435
WS_PORT_LIBRARIAN=11436
WS_PORT_EMBED=11437
WS_PORT_CODER=11438

# (Note: WS_PORT_EXPERIMENT used to live here for the opt-in
# llama-primary-experiment.service. With router mode all primary models
# share WS_PORT_PRIMARY and the experiment port is no longer used. The
# old units are masked rather than deleted; if they're ever brought back
# as a fallback path they'd need an entry here.)

# ── Per-role models ────────────────────────────────────────────────────────

# DEFAULT is what loads at boot or when the service is started without a
# specific model override. The unit file resolves
#   ${WS_MODELS_DIR}/${WS_PRIMARY_MODEL_DEFAULT}/<filename>.gguf
# at startup. The mapping from slug to filename lives inside the unit
# file's ExecStart line.
#
# AVAILABLE is the catalog of models this role *could* host. Today's
# static units only load DEFAULT; tomorrow's llama-swap reads AVAILABLE
# to know what it can swap to. Listing a model in AVAILABLE does not
# load it; it just announces the option.

WS_PRIMARY_MODEL_DEFAULT=glm-4.7-flash
WS_PRIMARY_MODELS_AVAILABLE="glm-4.7-flash qwen3-coder-30b qwen3-next-80b"

WS_SECONDARY_MODEL_DEFAULT=qwen3-4b-instruct-2507
WS_SECONDARY_MODELS_AVAILABLE="qwen3-4b-instruct-2507 aya-expanse-8b"

WS_EMBED_MODEL_DEFAULT=multilingual-e5-large
WS_EMBED_MODELS_AVAILABLE="multilingual-e5-large mxbai-embed-large"

WS_CODER_MODEL_DEFAULT=qwen2.5-coder-3b-instruct
WS_CODER_MODELS_AVAILABLE="qwen2.5-coder-3b-instruct qwen2.5-coder-7b-instruct"

# ── Per-role context windows ──────────────────────────────────────────────

# Today's static units bake these in. When llama-swap arrives the values
# move into per-model entries in the swap config; this block goes away.

WS_PRIMARY_CONTEXT=65536
WS_SECONDARY_CONTEXT=32768
WS_EMBED_CONTEXT=512
WS_CODER_CONTEXT=4096
