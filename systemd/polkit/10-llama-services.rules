// Allow specific local users to start/stop/restart llama-* services
// without sudo.
//
// Scope: only the llama-server units listed below. Other systemd
// actions still require sudo as normal.
//
// Rationale: the listed users need to start these services on demand
// (they are not enabled at boot). Without this rule, each start/stop
// would prompt for a sudo password, which is bad UX for a per-session
// launcher.
//
// Customize before install: edit the allowedUsers array below to list
// the local accounts that should have passwordless control. The default
// lists a single placeholder; replace with your own username(s).
//
// Install location: /etc/polkit-1/rules.d/10-llama-services.rules
// Owned by: root, mode 0644.
// Sourced from: this file in the umbrella repo. The install script in
// scripts/install-systemd-units.sh installs it via sudo.

polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") {
        return;
    }
    var unit = action.lookup("unit");
    if (unit === null) {
        return;
    }
    var allowedUnits = [
        "llama-primary.service",
        "llama-primary-moe.service",
        "llama-secondary.service",
        "llama-embed.service",
        "llama-coder.service",
    ];
    if (allowedUnits.indexOf(unit) === -1) {
        return;
    }
    // EDIT THIS: list the local usernames that should have passwordless
    // start/stop/restart for the llama services. Add or remove entries
    // as needed for your machine.
    var allowedUsers = ["your-username-here"];
    if (allowedUsers.indexOf(subject.user) !== -1) {
        return polkit.Result.YES;
    }
});
