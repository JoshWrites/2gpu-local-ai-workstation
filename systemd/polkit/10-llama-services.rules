// Allow specific local users to start/stop/restart llama-* services
// without sudo.
//
// Scope: only the llama-server units listed below. Other systemd
// actions still require sudo as normal.
//
// Rationale: the listed users need to start these services on demand
// (they are not enabled at boot). Without this rule, each start/stop
// would prompt for a sudo password, which is bad UX for a per-session
// launcher.
//
// This file is a TEMPLATE. The allowedUsers array contains the literal
// token __WS_LLAMA_USERS__ which install-systemd-units.sh substitutes
// at install time using WS_LLAMA_USERS from /etc/workstation/system.env.
// Editing this template directly does not affect installed behavior;
// edit system.env (or its example) and reinstall.
//
// Install location: /etc/polkit-1/rules.d/10-llama-services.rules
// Owned by: root, mode 0644.

polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") {
        return;
    }
    var unit = action.lookup("unit");
    if (unit === null) {
        return;
    }
    var allowedUnits = [
        "llama-primary.service",
        "llama-primary-moe.service",
        "llama-primary-router.service",
        "llama-primary-experiment.service",
        "llama-secondary.service",
        "llama-embed.service",
        "llama-coder.service",
    ];
    if (allowedUnits.indexOf(unit) === -1) {
        return;
    }
    // The token __WS_LLAMA_USERS__ is replaced at install time with a
    // JSON array of usernames from WS_LLAMA_USERS in system.env. Do not
    // edit by hand on the installed copy -- edit system.env and rerun
    // scripts/install-systemd-units.sh.
    var allowedUsers = __WS_LLAMA_USERS__;
    if (allowedUsers.indexOf(subject.user) !== -1) {
        return polkit.Result.YES;
    }
});
