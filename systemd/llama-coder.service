[Unit]
Description=llama-server coder (Qwen2.5-Coder-3B-Instruct on 5700 XT / Vulkan1, port 11438) - edit-prediction sidecar for Zed and other OpenAI-compatible clients
# Description is literal text; systemd does not interpolate env-file vars
# here. If env values change, the labels above may drift.
#
# The llama-server binary path is hardcoded below; see llama-primary.service
# for why. All other paths and values come from /etc/workstation/system.env.

[Service]
Type=simple
EnvironmentFile=/etc/workstation/system.env
ExecStart=/home/levine/src/llama.cpp/llama-b8799-vulkan/llama-server \
  -m ${WS_MODELS_DIR}/qwen2.5-coder-3b/qwen2.5-coder-3b-instruct-q4_k_m.gguf \
  --device ${WS_GPU_SECONDARY_DEVICE} -ngl 99 -c ${WS_CODER_CONTEXT} \
  --host 127.0.0.1 --port ${WS_PORT_CODER}
Restart=on-failure
RestartSec=5s
KillSignal=SIGTERM
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal
