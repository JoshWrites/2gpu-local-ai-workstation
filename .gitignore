# Model weights — never commit
*.gguf
*.bin
*.safetensors
models/

# KV cache dumps
*.kv
aspects/
.slots/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / VSCodium extension build artifacts
node_modules/
dist/
*.vsix

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Logs and local state
*.log
logs/
.observer/refs/    # deep store — large, regenerable
!.observer/index.md

# Secrets
.env
.env.*
!.env.example

# Claude Code local state
.claude/

# Per-user private workspace. Personal context, working notes, anything
# the user does not want public. memory-bank/ lives under private/ as the
# canonical "live working memory" location; the empty starting point is
# at memory-bank-template/ at the repo root and stays tracked.
private/*
!private/README.md
!private/.gitignore


# Personal/working plans (use docs/ for public docs)
docs/superpowers/
docs/local-notes/
