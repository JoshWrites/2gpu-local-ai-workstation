new file mode 100644
index 000000000..57b653ac5
--- /dev/null
+++ b/packages/opencode/src/acp/pending-swap.ts
@@ -0,0 +1,34 @@
+// Workstation router-mode integration v2: shared pending-swap state.
+//
+// The picker handler in acp/agent.ts calls --preflight on the configured
+// swap script and stashes the resulting JSON in this map (keyed by
+// session id) when the user picks an unloaded model. The on-message check
+// in session/prompt.ts reads the map, raises a `swap` permission card via
+// permission.ask, and on Allow runs --execute. On Deny it reverts the
+// model selection and clears the entry.
+//
+// Module-level state because the two call sites live in different
+// packages (acp/ and session/) and there is no existing shared service
+// that fits this short-lived, single-process state.
+
+export type PendingSwap = {
+  target: string
+  previous: string | null
+  preflight: any
+  script: string
+  routerBase: string | null
+}
+
+const pendingSwaps = new Map<string, PendingSwap>()
+
+export function setPendingSwap(sessionId: string, swap: PendingSwap): void {
+  pendingSwaps.set(sessionId, swap)
+}
+
+export function getPendingSwap(sessionId: string): PendingSwap | undefined {
+  return pendingSwaps.get(sessionId)
+}
+
+export function clearPendingSwap(sessionId: string): void {
+  pendingSwaps.delete(sessionId)
+}
